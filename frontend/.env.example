# Strapi API, server-side only. Never expose this to the browser.
STRAPI_API_URL="https://your-strapi-instance-here"

# Custom, narrowly-scoped Strapi API token used ONLY by /api/auth/redeem-invite.
# Server-side only — never prefix with NEXT_PUBLIC_.
#
# Type must be `Custom`, granting exactly four permissions and nothing else:
#   Invite                    -> find, update
#   Users-permissions User    -> create
#   Users-permissions Role    -> find     (POST /api/users requires an explicit role id)
# Set its duration to Unlimited: expiry here is a scheduled outage, not a security
# boundary. The boundary is the scope. See scripts/check-invite-token.js.
#
# ⚠ This file, and every `.env*`, is gitignored — setting the token on your laptop
# does NOT deploy it. It must exist in the environment where Next.js actually runs.
# Next reads, first-value-wins: the real environment, .env.<NODE_ENV>.local,
# .env.local, .env.<NODE_ENV>, .env. If Next runs under a process manager, the
# variable has to be in *that* process's environment.
#
# Verify with:  node scripts/check-invite-token.js
# An UNSET token makes registration answer "Registration is unavailable" (503).
# A WRONG or revoked token instead answers "That invite code is not valid" (400),
# because the invite lookup 401s and is indistinguishable from a bad code.
STRAPI_INVITE_TOKEN="your-custom-api-token-here"

# Cross-app: reads shows from the slownames Strapi. See app/lib/showsTodoCreator.ts.
NEXT_PUBLIC_STRAPI_BAND_API_URL="https://your-band-notebook-strapi-instance-here"
NEXT_PUBLIC_BAND_NOTEBOOK_USER="your-username-here"
