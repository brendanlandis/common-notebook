    "email": {
      "type": "email"
    },
    "expiresAt": {
      "type": "datetime"
    },
    "usedAt": {
      "type": "datetime"
    },
    "usedBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
