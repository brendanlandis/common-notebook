{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "world": {
      "type": "enumeration",
      "enum": [
        "life stuff",
        "music admin",
        "make music",
        "day job",
        "computer",
        "stuff"
      ]
    },
    "importance": {
      "type": "enumeration",
      "default": "normal",
      "enum": [
        "normal",
        "top of mind",
        "later"
      ]
    },
    "owner": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "private": true
    },
    "slug": {
      "type": "string"
    },
    "tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::task.task",
      "mappedBy": "project"
    },
    "projectType": {
      "type": "enumeration",
      "default": "default",
      "enum": [
        "default",
        "chores",
        "wishlist",
        "errands",
        "in the mail",
        "buy stuff"
      ]
    }
  }
}
