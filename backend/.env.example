HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Where the Next.js app lives. Used to build the password-reset link that Strapi
# emails out; seeded into users-permissions advanced settings on boot.
FRONTEND_URL=http://localhost:3000

# Password-reset email delivery. Without SMTP_HOST, Strapi falls back to the
# `sendmail` provider, which will not deliver from a droplet — bootstrap() warns.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=notebook@example.com
EMAIL_FROM_NAME="Common Notebook"
EMAIL_REPLY_TO=

# Access-token lifespan in seconds. Only override for testing expiry.
# ACCESS_TOKEN_LIFESPAN=1800

AWS_ACCESS_KEY_ID=tobemodified
AWS_ACCESS_SECRET=tobemodified
AWS_REGION=tobemodified
AWS_BUCKET=tobemodified
