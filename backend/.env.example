HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Where the Next.js app lives. Used to build the password-reset link that Strapi
# emails out; seeded into users-permissions advanced settings on boot.
FRONTEND_URL=http://localhost:3000

# Password-reset email delivery. Without SMTP_HOST the app uses a no-op transport
# and sends nothing — never Strapi's `sendmail` default, which delivers straight to
# the recipient's MX from whatever machine happens to be running.
#
# 465 and 2465 use implicit TLS; 25, 587, 2587 and 2525 use STARTTLS.
# config/plugins.ts derives that from the port.
#
# EMAIL_FROM's domain must publish SPF (and ideally DKIM) or the mail is rejected:
# commonnotebook.com has DMARC p=reject, so a misaligned message is refused
# outright rather than spam-foldered.
#
# Verify with:  node scripts/check-smtp.js   (diagnoses ports/TLS/credentials)
#          then node scripts/test-email.js --to you@example.com
#
# Sending is OPT-IN. Without EMAIL_ENABLED=true, config/plugins.ts installs a no-op
# transport so a local Strapi cannot send real mail using these credentials.
# `strapi start` does NOT set NODE_ENV, so production must set this explicitly.
# bootstrap() logs the chosen transport: look for "[email] transport:".
EMAIL_ENABLED=true

# DigitalOcean blocks outbound 25/465/587. Forward Email's alternates work:
# 2465 (implicit TLS), 2587 / 2525 (STARTTLS).
SMTP_HOST=smtp.forwardemail.net
SMTP_PORT=2465

# nodemailer resolves A *and* AAAA and picks one AT RANDOM, treating a link-local
# fe80:: address as "IPv6 support". On a host with no IPv6 route that means ~half
# of sends die with ENETUNREACH, intermittently. config/plugins.ts auto-detects
# this and pins SMTP to IPv4. Set to false only if you have working IPv6.
# SMTP_FORCE_IPV4=true
SMTP_USERNAME=robot@commonnotebook.com
SMTP_PASSWORD=
EMAIL_FROM=robot@commonnotebook.com
EMAIL_FROM_NAME="Common Notebook"
# Where replies go. Leave blank to reply to EMAIL_FROM.
EMAIL_REPLY_TO=

# Access-token lifespan in seconds. Only override for testing expiry.
# ACCESS_TOKEN_LIFESPAN=1800

AWS_ACCESS_KEY_ID=tobemodified
AWS_ACCESS_SECRET=tobemodified
AWS_REGION=tobemodified
AWS_BUCKET=tobemodified
